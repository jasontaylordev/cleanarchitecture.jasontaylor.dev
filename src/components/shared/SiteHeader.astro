---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="Clean Architecture home">
      <img src="/logo.svg" width="40" height="40" alt="" aria-hidden="true" />
      <span class="logo-text">Clean Architecture</span>
    </a>

    <nav class="header-nav" aria-label="Main navigation">
<a
        href="https://github.com/jasontaylordev/CleanArchitecture"
        class="nav-link nav-link--icon"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span class="sr-only">GitHub</span>
      </a>
      <a
        href="https://www.nuget.org/packages/Clean.Architecture.Solution.Template"
        class="nav-link nav-link--icon"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on NuGet"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M16 2a14 14 0 1 0 14 14A14 14 0 0 0 16 2zm-3.4 19.6a4.6 4.6 0 1 1 4.6-4.6 4.6 4.6 0 0 1-4.6 4.6zm9.6-9.2h-4.4V8h4.4a2.2 2.2 0 0 1 0 4.4z"/>
        </svg>
        <span class="sr-only">NuGet</span>
      </a>
      <div class="nav-divider" aria-hidden="true"></div>
      <label class="theme-select-wrapper">
        <span class="sr-only">Select theme</span>
        <!-- Label icon: positioned absolutely over the select -->
        <svg class="theme-icon theme-icon-dark" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.64 13a1 1 0 0 0-1.05-.14 8.049 8.049 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 14 11.69 1 1 0 0 0-.36-1.05Zm-9.5 6.69A8.14 8.14 0 0 1 7.08 5.22v.27a10.15 10.15 0 0 0 10.14 10.14 9.784 9.784 0 0 0 2.1-.22 8.11 8.11 0 0 1-7.18 4.32v-.04Z"/></svg>
        <svg class="theme-icon theme-icon-light" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1Zm.64 5-.71.71a1 1 0 0 0 0 1.41 1 1 0 0 0 1.41 0l.71-.71A1 1 0 0 0 5.64 17ZM12 5a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1Zm5.66 2.34a1 1 0 0 0 .7-.29l.71-.71a1 1 0 1 0-1.41-1.41l-.66.71a1 1 0 0 0 0 1.41 1 1 0 0 0 .66.29Zm-12-.29a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.71-.71a1.004 1.004 0 1 0-1.43 1.41l.73.71ZM21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2Zm-2.64 6A1 1 0 0 0 17 18.36l.71.71a1 1 0 0 0 1.41 0 1 1 0 0 0 0-1.41l-.76-.66ZM12 6.5a5.5 5.5 0 1 0 5.5 5.5A5.51 5.51 0 0 0 12 6.5Zm0 9a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm0 3.5a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1Z"/></svg>
        <svg class="theme-icon theme-icon-auto" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 14h-1V7a3 3 0 0 0-3-3H7a3 3 0 0 0-3 3v7H3a1 1 0 0 0-1 1v2a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3v-2a1 1 0 0 0-1-1ZM6 7a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v7H6V7Zm14 10a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-1h16v1Z"/></svg>
        <select id="theme-select" autocomplete="off">
          <option value="dark">Dark</option>
          <option value="light">Light</option>
          <option value="auto">Auto</option>
        </select>
        <!-- Caret icon: positioned absolutely -->
        <svg class="theme-caret" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17 9.17a1 1 0 0 0-1.41 0L12 12.71 8.46 9.17a1 1 0 1 0-1.41 1.42l4.24 4.24a1.002 1.002 0 0 0 1.42 0L17 10.59a1.002 1.002 0 0 0 0-1.42Z"/></svg>
      </label>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(2, 8, 23, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    padding: 0 1.5rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 1.5rem;
    color: #f8fafc;
    text-decoration: none;
    transition: opacity 0.2s;
    letter-spacing: -0.02em;
  }

  .logo:hover {
    opacity: 0.85;
  }

  .logo-text {
    letter-spacing: -0.01em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.875rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #cbd5e1;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link:hover {
    color: #f8fafc;
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-divider {
    width: 0;
    height: 2rem;
    border-inline-end: 1px solid #1e293b;
    margin: 0 0.75rem;
  }

  :global([data-theme="light"]) .nav-divider {
    border-inline-end-color: #e2e8f0;
  }

  .nav-link--icon {
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
  }

  :global(.landing-page .header-nav .nav-link--icon) {
    color: #cbd5e1;
  }

  :global([data-theme="light"] .landing-page .header-nav .nav-link--icon) {
    color: #475569;
  }

  /* Theme select — mirrors Starlight's Select.astro layout */
  .theme-select-wrapper {
    --icon-size: 0.875rem;
    --caret-size: 1.25rem;
    --pad: 0.5rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: #cbd5e1;
    cursor: pointer;
    transition: color 0.2s;
  }

  .theme-select-wrapper:hover {
    color: #f8fafc;
  }

  .theme-icon, .theme-caret {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .theme-icon {
    font-size: var(--icon-size);
    inset-inline-start: 0;
    display: none;
  }

  :global([data-theme-select="dark"]) .theme-icon-dark { display: block; }
  :global([data-theme-select="light"]) .theme-icon-light { display: block; }
  :global([data-theme-select="auto"]) .theme-icon-auto { display: block; }
  /* Default (no attribute yet) = dark */
  :global(html:not([data-theme-select])) .theme-icon-dark { display: block; }

  .theme-caret {
    font-size: var(--caret-size);
    inset-inline-end: 0;
  }

  select#theme-select {
    border: 0;
    padding-block: 0.625rem;
    padding-inline-start: calc(var(--icon-size) + var(--pad) + 0.25rem);
    padding-inline-end: calc(var(--caret-size) + var(--pad) + 0.25rem);
    margin-inline: calc(var(--pad) * -1);
    width: calc(6.25em + var(--pad) * 2);
    background: transparent;
    color: inherit;
    cursor: pointer;
    appearance: none;
    font-family: inherit;
    font-size: var(--sl-text-sm, 0.875rem);
    line-height: normal;
  }

  select#theme-select option {
    background-color: #0f172a;
    color: #f1f5f9;
  }

  :global([data-theme="light"]) select#theme-select option {
    background-color: #ffffff;
    color: #1e293b;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Light mode header overrides */
  :global([data-theme="light"]) .site-header {
    background: rgba(255, 255, 255, 0.85);
    border-bottom-color: rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="light"]) .logo {
    color: #0f172a;
  }

  :global([data-theme="light"]) .nav-link {
    color: #475569;
  }

  :global([data-theme="light"]) .nav-link:hover {
    color: #0f172a;
    background: rgba(0, 0, 0, 0.05);
  }

  :global([data-theme="light"]) .theme-select-wrapper {
    color: #475569;
  }

  :global([data-theme="light"]) .theme-select-wrapper:hover {
    color: #0f172a;
  }

  @media (max-width: 480px) {
    .logo-text {
      display: none;
    }
  }
</style>

<script>
  type Theme = 'auto' | 'dark' | 'light';

  const parseTheme = (t: unknown): Theme =>
    t === 'dark' || t === 'light' ? t : 'auto';

  const getSystemTheme = (): Theme =>
    matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

  function applyTheme(theme: Theme) {
    document.documentElement.dataset.themeSelect = theme;
    document.documentElement.dataset.theme = theme === 'auto' ? getSystemTheme() : theme;
    localStorage.setItem('starlight-theme', theme === 'dark' || theme === 'light' ? theme : '');
    const sel = document.getElementById('theme-select') as HTMLSelectElement | null;
    if (sel) sel.value = theme;
  }

  applyTheme(parseTheme(localStorage.getItem('starlight-theme')));

  document.getElementById('theme-select')?.addEventListener('change', (e) => {
    applyTheme(parseTheme((e.target as HTMLSelectElement).value));
  });
</script>
