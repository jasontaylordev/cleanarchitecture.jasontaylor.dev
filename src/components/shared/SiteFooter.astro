---
const year = new Date().getFullYear();

let version = '';
try {
  const res = await fetch('https://azuresearch-usnc.nuget.org/query?q=packageid:Clean.Architecture.Solution.Template&prerelease=false');
  if (res.ok) {
    const data = await res.json();
    version = data.data?.[0]?.version ?? '';
  }
} catch {}
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-tagline footer-tagline--heading">Clean Architecture Solution Template</p>
        <p class="footer-tagline">
          Designed and built by <a href="https://github.com/jasontaylordev" target="_blank" rel="noopener noreferrer">Jason Taylor</a> with the help of many <a href="https://github.com/jasontaylordev/cleanarchitecture/graphs/contributors" target="_blank" rel="noopener noreferrer">contributors</a>.
        </p>
        <div class="footer-social">
          <!-- GitHub -->
          <a href="https://github.com/jasontaylordev/CleanArchitecture" target="_blank" rel="noopener noreferrer" aria-label="GitHub repository">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
          <!-- NuGet -->
          <a href="https://www.nuget.org/packages/Clean.Architecture.Solution.Template" target="_blank" rel="noopener noreferrer" aria-label="NuGet package">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
              <path d="M16 2a14 14 0 1 0 14 14A14 14 0 0 0 16 2zm-3.4 19.6a4.6 4.6 0 1 1 4.6-4.6 4.6 4.6 0 0 1-4.6 4.6zm9.6-9.2h-4.4V8h4.4a2.2 2.2 0 0 1 0 4.4z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-links">
        <h3>Documentation</h3>
        <ul>
          <li><a href="/docs/getting-started/">Overview</a></li>
          <li><a href="/docs/getting-started/installation/">Installation</a></li>
          <li><a href="/docs/getting-started/first-project/">First Project</a></li>
          <li><a href="/docs/architecture/">Architecture</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h3>Features</h3>
        <ul>
          <li><a href="/docs/features/multiple-ui-options/">Multiple UI options</a></li>
          <li><a href="/docs/features/multiple-database-options/">Multiple database options</a></li>
          <li><a href="/docs/features/structured-use-cases/">Structured use cases</a></li>
          <li><a href="/docs/features/pipeline-behaviours/">Behaviours, not boilerplate</a></li>
          <li><a href="/docs/features/automated-tests/">Automated tests</a></li>
          <li><a href="/docs/features/aspire/">Aspire orchestration</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h3>Community</h3>
        <ul>
          <li>
            <a href="https://github.com/jasontaylordev/CleanArchitecture" target="_blank" rel="noopener noreferrer">
              GitHub Repository
            </a>
          </li>
          <li>
            <a href="https://github.com/jasontaylordev/CleanArchitecture/discussions" target="_blank" rel="noopener noreferrer">
              Discussions
            </a>
          </li>
          <li>
            <a href="https://github.com/jasontaylordev/CleanArchitecture/issues" target="_blank" rel="noopener noreferrer">
              Issues
            </a>
          </li>
          <li>
            <a href="https://www.nuget.org/packages/Clean.Architecture.Solution.Template" target="_blank" rel="noopener noreferrer">
              NuGet Package
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>Code licensed <a href="https://github.com/jasontaylordev/CleanArchitecture/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT</a>.{version && <> Current version <a href={`https://www.nuget.org/packages/Clean.Architecture.Solution.Template/${version}`} target="_blank" rel="noopener noreferrer">{version}</a>.</>}</p>
      <p>Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> and <a href="https://starlight.astro.build" target="_blank" rel="noopener noreferrer">Starlight</a>.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface-1);
    border-top: 1px solid var(--border);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .footer-tagline--heading {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .footer-tagline a {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .footer-tagline a:hover {
    color: var(--brand);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-social a {
    color: var(--text-secondary);
    transition: color 0.2s;
    display: flex;
  }

  .footer-social a:hover {
    color: var(--brand);
  }

  .footer-links h3 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--brand);
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-bottom a {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .footer-bottom a:hover {
    color: var(--brand);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-brand {
      grid-column: span 1;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
