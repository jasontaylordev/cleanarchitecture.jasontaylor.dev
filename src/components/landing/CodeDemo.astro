---
const steps = [
  {
    number: '01',
    title: 'Install the template',
    desc: 'Install the template from NuGet once. It stays available for all future projects.',
    command: 'dotnet new install Clean.Architecture.Solution.Template',
  },
  {
    number: '02',
    title: 'Create your project',
    desc: 'Scaffold a new solution with your preferred frontend and database in seconds.',
    command: 'dotnet new ca-sln -cf react -db sqlserver -o .\\MyApp',
  },
  {
    number: '03',
    title: 'Run the app',
    desc: 'One command starts your entire stack. Frontend, API, and database boot together. Nothing to install or configure.',
    command: 'cd MyApp && dotnet run --project .\\src\\AppHost',
  },
];
---
<section class="code-demo" id="get-started">
  <div class="code-demo-inner">
    <div class="code-demo-header">
      <h2 class="code-demo-title">Up and running in minutes</h2>
      <p class="code-demo-subtitle">Three commands to a production-ready solution structure.</p>
    </div>

    <div class="steps">
      {steps.map(step => (
        <div class="step">
          <div class="step-meta">
            <span class="step-number" aria-hidden="true">{step.number}</span>
            <div class="step-info">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.desc}</p>
            </div>
          </div>
          <div class="terminal" role="region" aria-label={`Terminal: ${step.title}`}>
            <div class="terminal-bar">
              <span class="dot dot--red" aria-hidden="true"></span>
              <span class="dot dot--yellow" aria-hidden="true"></span>
              <span class="dot dot--green" aria-hidden="true"></span>
            </div>
            <div class="terminal-body-wrap">
              <pre class="terminal-body"><code><span class="prompt">$</span> <span class="cmd">{step.command}</span></code></pre>
              <button class="copy-btn" data-command={step.command} aria-label="Copy command" title="Copy to clipboard">
                <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="code-demo-footer">
      <a href="/docs/getting-started/first-project/" class="demo-link">
        See all project options
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .code-demo {
    padding: 5rem 1.5rem;
    background: var(--surface-1);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .code-demo-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .code-demo-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .code-demo-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .code-demo-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .step {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: center;
  }

  .step:nth-child(even) {
    direction: rtl;
  }

  .step:nth-child(even) > * {
    direction: ltr;
  }

  .step-meta {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-number {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    color: var(--brand);
    opacity: 0.35;
    line-height: 1;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .step-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.375rem;
    letter-spacing: -0.01em;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .terminal {
    background: #0d1117;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .terminal-bar {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    padding: 0.625rem 0.875rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .terminal-body-wrap {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.4);
    display: flex;
    align-items: center;
    padding: 0.25rem;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .copy-btn .check-icon { display: none; color: #28c840; }
  .copy-btn.copied .copy-icon { display: none; }
  .copy-btn.copied .check-icon { display: block; }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #febc2e; }
  .dot--green { background: #28c840; }

  .terminal-body {
    padding: 1.25rem 1.25rem;
    margin: 0;
    font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', 'Consolas', monospace;
    font-size: 0.85rem;
    line-height: 1.6;
    white-space: pre;
    overflow-x: auto;
  }

  .prompt {
    color: #28c840;
    user-select: none;
    margin-right: 0.5rem;
  }

  .cmd {
    color: #e2e8f0;
  }

  .code-demo-footer {
    text-align: center;
    margin-top: 3rem;
  }

  .demo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand);
    transition: gap 0.2s;
  }

  .demo-link:hover {
    gap: 0.625rem;
  }

  @media (max-width: 720px) {
    .step {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .step:nth-child(even) {
      direction: ltr;
    }
  }

  :global([data-theme="light"]) .terminal {
    background: #f6f8fa;
    border-color: rgba(0, 0, 0, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="light"]) .terminal-bar {
    background: rgba(0, 0, 0, 0.04);
    border-bottom-color: rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="light"]) .cmd {
    color: #1e293b;
  }

  :global([data-theme="light"]) .copy-btn {
    color: rgba(0, 0, 0, 0.35);
  }

  :global([data-theme="light"]) .copy-btn:hover {
    color: rgba(0, 0, 0, 0.7);
  }
</style>

<script>
  document.querySelectorAll('.code-demo .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const command = btn.getAttribute('data-command');
      await navigator.clipboard.writeText(command);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 2000);
    });
  });
</script>
